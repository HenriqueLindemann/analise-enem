# Microdados INEP originais (muito grandes - baixar do portal INEP)
# https://www.gov.br/inep/pt-br/acesso-a-informacao/dados-abertos/microdados/enem
microdados/
DADOS/

# Microdados limpos - manter estrutura mas ignorar arquivos grandes
microdados_limpos/**/DADOS_ENEM*.csv
# Nota: ITENS_PROVA*.csv são incluídos (pequenos, essenciais para cálculo)

# Outputs de análise
graficos/
graficos_tri/
resultados/

# Arquivos gerados pelos scripts de teste (não são source)
tests/suite_testes_tri.txt
tests/suite_testes_completos.txt
tests/provas_problematicas.md

# Relatórios PDF gerados
relatorios/*.pdf
!relatorios/EXEMPLO_relatorio.pdf

